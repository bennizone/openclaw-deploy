{
  "auth": {
    "profiles": {
      "minimax:global": {
        "provider": "minimax",
        "mode": "api_key"
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "minimax": {
        "baseUrl": "https://api.minimax.io/anthropic",
        "api": "anthropic-messages",
        "authHeader": true,
        "models": [
          {
            "id": "MiniMax-M2.7",
            "name": "MiniMax M2.7",
            "reasoning": true,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0.3,
              "output": 1.2,
              "cacheRead": 0.06,
              "cacheWrite": 0.375
            },
            "contextWindow": 204800,
            "maxTokens": 131072
          }
        ]
      },
      "llama": {
        "baseUrl": "http://${GPU_SERVER_IP}:8080",
        "api": "openai-completions",
        "models": [
          {
            "id": "Qwen3.5-9B-Opus-Distilled-v2-Q4_K_M",
            "name": "Qwen 3.5 9B Opus-Distilled v2",
            "contextWindow": 98304,
            "maxTokens": 8192,
            "note": "GPU ctx-size=196608 mit parallel=2 ergibt 98304 pro Slot"
          }
        ]
      },
      "ha-cloud-stt": {
        "baseUrl": "${HA_URL}",
        "apiKey": "ha-voice-internal",
        "models": []
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "minimax/MiniMax-M2.7",
        "fallbacks": ["llama/Qwen3.5-9B-Opus-Distilled-v2-Q4_K_M"]
      },
      "models": {
        "minimax/MiniMax-M2.7": {
          "alias": "Minimax"
        }
      },
      "workspace": "/home/openclaw/.openclaw/workspace",
      "memorySearch": {
        "provider": "openai",
        "remote": {
          "baseUrl": "http://${GPU_SERVER_IP}:8081"
        },
        "fallback": "local",
        "model": "bge-m3"
      }
    },
    "list": [
      {
        "id": "benni",
        "default": true,
        "name": "Benni",
        "workspace": "/home/openclaw/.openclaw/workspace-benni"
      },
      {
        "id": "domi",
        "name": "Domi",
        "workspace": "/home/openclaw/.openclaw/workspace-domi"
      },
      {
        "id": "household",
        "name": "Household",
        "workspace": "/home/openclaw/.openclaw/workspace-household"
      }
    ]
  },
  "tools": {
    "profile": "full",
    "agentToAgent": {
      "enabled": true,
      "allow": [
        "benni",
        "domi",
        "household"
      ]
    },
    "media": {
      "audio": {
        "enabled": true,
        "language": "de-DE",
        "echoTranscript": true,
        "echoFormat": "\ud83c\udfa4 \"{transcript}\"",
        "models": [
          {
            "provider": "ha-cloud-stt"
          }
        ]
      }
    }
  },
  "bindings": [
    {
      "agentId": "benni",
      "match": {
        "channel": "whatsapp",
        "accountId": "benni"
      }
    },
    {
      "agentId": "domi",
      "match": {
        "channel": "whatsapp",
        "accountId": "domi"
      }
    }
  ],
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "channels": {
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "selfChatMode": false,
      "allowFrom": [
        "+491234567890"
      ],
      "groupPolicy": "allowlist",
      "debounceMs": 0,
      "mediaMaxMb": 50
    },
    "_matrix_example": {
      "_comment": "Matrix-Channel (optional) — siehe docs/matrix-conduit-setup.md",
      "enabled": true,
      "homeserver": "https://${MATRIX_HOMESERVER}",
      "accessToken": "${MATRIX_ACCESS_TOKEN}",
      "deviceName": "OpenClaw Gateway",
      "autoJoin": "allowlist",
      "dm": {
        "policy": "allowlist",
        "allowFrom": [
          "@user:${MATRIX_HOMESERVER}"
        ]
      }
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789"
      ]
    },
    "auth": {
      "mode": "token",
      "token": "${GATEWAY_AUTH_TOKEN}"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        }
      }
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send"
      ]
    }
  },
  "mcp": {
    "servers": {}
  },
  "skills": {
    "entries": {}
  },
  "plugins": {
    "slots": {
      "memory": "none"
    },
    "entries": {
      "openclaw-sonarr-radarr": {
        "enabled": true,
        "config": {
          "sonarrUrl": "${SONARR_URL}",
          "sonarrApiKey": "${SONARR_API_KEY}",
          "radarrUrl": "${RADARR_URL}",
          "radarrApiKey": "${RADARR_API_KEY}",
          "seriesQualityProfile": "Up to 720p",
          "movieQualityProfile": "Up to 1080p"
        }
      },
      "openclaw-ha-voice": {
        "enabled": true,
        "config": {
          "url": "${HA_URL}",
          "token": "${HA_LONG_LIVED_TOKEN}",
          "sttProvider": "stt.home_assistant_cloud",
          "ttsEngine": "tts.home_assistant_cloud",
          "language": "de-DE",
          "ttsVoice": "KatjaNeural"
        }
      },
      "openclaw-memory-recall": {
        "enabled": true,
        "config": {
          "qdrantUrl": "http://localhost:6333",
          "embedUrl": "http://${GPU_SERVER_IP}:8081",
          "embedFallbackUrl": "http://localhost:8081",
          "embeddingModel": "bge-m3",
          "topK": 5
        }
      }
    }
  }
}
