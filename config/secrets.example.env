# Required Secrets for OpenClaw Deploy
# Copy to ~/.openclaw/.env (OpenClaw reads this automatically)
# NEVER commit real values to git!

# MiniMax API Key (required for primary LLM)
MINIMAX_API_KEY=

# Home Assistant Long-Lived Access Token
HA_LONG_LIVED_TOKEN=

# Gateway Authentication Token (generate with: openssl rand -hex 24)
GATEWAY_AUTH_TOKEN=

# Sonarr API Key (optional, for media management)
SONARR_API_KEY=

# Radarr API Key (optional, for media management)
RADARR_API_KEY=

# GPU Server IP Address
GPU_SERVER_IP=

# Sonarr/Radarr URLs (optional)
SONARR_URL=
RADARR_URL=

# WhatsApp allowed phone numbers (comma-separated, with country code)
# Example: +491234567890
WHATSAPP_ALLOW_FROM=
